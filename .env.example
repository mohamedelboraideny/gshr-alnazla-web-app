# --- SERVER-SIDE (Local Machine & Cloud Server) ---
# Used by Express backend (server.ts)
SUPABASE_URL=
SUPABASE_SECRET_KEY=      # (Formerly service_role) - ONLY for server-side
SUPABASE_PUBLISHABLE_KEY=  # (Formerly anon) - Safe for client-side

# --- FRONTEND (GitHub Pages / Static Mode) ---
# Used by React frontend (CharityStore.tsx) when VITE_API_MODE=direct
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY= # (Formerly anon) - Safe for client-side

# --- CONFIGURATION ---
# Set to 'proxy' for Local/Cloud Server (uses Express backend)
# Set to 'direct' for GitHub Pages (talks directly to Supabase)
VITE_API_MODE=proxy
