{
  "name": "gshr-alnazla-management",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "prod": "tsc && vite build && vite preview",
    "predeploy": "npm run build",
    "clean-gh-pages": "node -e \"try { require('fs').rmSync('node_modules/.cache/gh-pages', { recursive: true, force: true }) } catch(e) {}\"",
    "deploy": "npm run clean-gh-pages && gh-pages -d dist"
  },
  "dependencies": {
    "lucide-react": "^0.378.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.23.1"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.1",
    "gh-pages": "^6.1.1",
    "typescript": "^5.9.3",
    "vite": "^5.4.21"
  }
}
