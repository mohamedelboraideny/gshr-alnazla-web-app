{
  "name": "gshr-alnazla-management",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "prod": "tsc && vite build && vite preview",
    "predeploy": "npm run build",
    "clean-gh-pages": "node -e \"try { require('fs').rmSync('node_modules/.cache/gh-pages', { recursive: true, force: true }) } catch(e) {}\"",
    "deploy": "npm run clean-gh-pages && gh-pages -d dist"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.103.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "lucide-react": "^0.378.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.23.1",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.1",
    "gh-pages": "^6.1.1",
    "typescript": "^5.4.5",
    "vite": "^5.3.1"
  }
}
